# ══════════════════════════════════════════════════════════════════════════════
# .env.example — VentLive AI
# ══════════════════════════════════════════════════════════════════════════════
#
# PURPOSE:
#   This file documents every environment variable used by VentLive AI.
#   It contains placeholder values only — no real secrets.
#
# SETUP:
#   1. Copy this file to .env
#      cp .env.example .env
#   2. Fill in your real values (see comments for where to get each one)
#   3. Never commit .env to version control
#
# WHICH VARIABLES ARE REQUIRED:
#   Required:   GCP_PROJECT, GEMINI_API_KEY
#   Optional:   Everything else has a working default shown below
#
# WHERE THESE VARIABLES ARE READ:
#   GCP_PROJECT        → case_memory.py, live_session.py, main.py
#   GCP_LOCATION       → live_session.py, main.py
#   GCP_MODEL          → live_session.py, main.py
#   GEMINI_API_KEY     → gemini_handler.py
#   VENTLIVE_API_KEY   → main.py (REST + WebSocket authentication)
#   GOOGLE_APPLICATION_CREDENTIALS → google-cloud-firestore SDK (implicit)
#   PORT               → deploy.sh local target
#   DOCKER_PORT        → deploy.sh docker target (container internal port)
#   HOST_PORT          → deploy.sh docker target (host-side port mapping)
#   SERVICE_NAME       → deploy.sh cloudrun target
#   IMAGE_TAG          → deploy.sh docker + cloudrun targets
#   VM_INSTANCE        → deploy.sh vm target
#   VM_ZONE            → deploy.sh vm target
#   VM_USER            → deploy.sh vm target
#
# ══════════════════════════════════════════════════════════════════════════════


# ── Google Cloud Project ──────────────────────────────────────────────────────
# Required.
#
# Your GCP project ID — NOT the project name or project number.
# Find it in GCP Console → top navigation bar → project selector
# Or run: gcloud config get-value project
#
# Used by:
#   • Firestore client (case_memory.py) — identifies the database
#   • Gemini Live client (live_session.py) — Vertex AI project billing
#   • Health endpoint (main.py) — displayed in /health response
#
# Example values:
#   ventlive-ai
#   my-gcp-project-123456
#   icu-decision-support-prod
GCP_PROJECT=your-gcp-project-id


# ── Gemini API Key ────────────────────────────────────────────────────────────
# Required.
#
# Used by Gemini 2.5 Flash for clinical NLU extraction — parsing ventilator
# parameters, ABG values, hemodynamics, and weaning indicators from
# physician speech transcripts.
#
# Get yours at: https://aistudio.google.com/apikey
#
# Security notes:
#   • Never commit this value to version control
#   • Never pass via -e flag in docker run (appears in shell history)
#   • Always use --env-file .env with Docker
#   • On Cloud Run: injected via --set-env-vars in deploy.sh (not stored in image)
#
# Used by: gemini_handler.py → client = genai.Client(api_key=GEMINI_API_KEY)
GEMINI_API_KEY=your-gemini-api-key-from-aistudio


# ── Google Cloud Location / Region ───────────────────────────────────────────
# Optional. Default: us-central1
#
# The GCP region for:
#   • Gemini Live 2.5 Flash Native Audio (Vertex AI endpoint)
#   • Cloud Run service deployment
#   • Firestore database (set at database creation time — this does not move it)
#
# Gemini Live availability varies by region. Verified working regions:
#   us-central1    (Iowa — lowest latency for US)
#   us-east4       (Northern Virginia)
#   europe-west4   (Netherlands)
#
# Check current availability:
#   https://cloud.google.com/vertex-ai/generative-ai/docs/learn/locations
#
# Used by: live_session.py, main.py, deploy.sh cloudrun + vm targets
GCP_LOCATION=us-central1


# ── Gemini Live Model ─────────────────────────────────────────────────────────
# Optional. Default: gemini-live-2.5-flash-native-audio
#
# The Vertex AI model string for the real-time voice interface.
# This model handles:
#   • Bidirectional PCM audio streaming (16kHz in, 24kHz out)
#   • Server-side voice activity detection (VAD)
#   • Natural barge-in interruption detection
#   • Input and output speech transcription
#   • Text injection for spoken clinical assessments (Puck voice, en-US)
#
# Do not change this unless Google releases a newer Live model and you
# have verified it supports the LiveConnectConfig parameters used in
# live_session.build_live_config().
#
# Used by: live_session.py, main.py, deploy.sh
GCP_MODEL=gemini-live-2.5-flash-native-audio


# ── VentLive API Key ──────────────────────────────────────────────────────────
# Optional. Default: ventlive-demo-2026
#
# Shared secret used to authenticate:
#   • All REST API endpoints (X-API-Key header)
#     POST /cases/new, GET /cases, DELETE /cases/{id}, POST /analyze, etc.
#   • WebSocket connection (/ws/live/{case_id}?api_key=...)
#
# The browser frontend sends this key in every request:
#   index.html → const HEADERS = { "X-API-Key": "ventlive-demo-2026" }
#
# IMPORTANT: If you change this value here, you must also update
# the matching constant in index.html (~line 750):
#   const HEADERS = {"Content-Type":"application/json",
#                    "ngrok-skip-browser-warning":"true",
#                    "X-API-Key":"YOUR-NEW-KEY-HERE"};
#   const GH      = {"ngrok-skip-browser-warning":"true",
#                    "X-API-Key":"YOUR-NEW-KEY-HERE"};
#
# For production: use a randomly generated string of at least 32 characters.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Used by: main.py → API_KEY = os.environ.get("VENTLIVE_API_KEY", "ventlive-demo-2026")
VENTLIVE_API_KEY=ventlive-demo-2026


# ── Google Application Credentials ───────────────────────────────────────────
# Optional. No default — falls back to application default credentials (ADC).
#
# Path to a GCP service account JSON key file on the local filesystem.
# Required when running locally without gcloud ADC configured.
# NOT needed on Cloud Run (uses attached service account automatically).
# NOT needed on GCE VM (uses VM service account automatically).
#
# How to create a service account key:
#   1. GCP Console → IAM & Admin → Service Accounts
#   2. Create service account with these roles:
#        Cloud Datastore User      (Firestore read/write)
#        Vertex AI User            (Gemini Live API access)
#        AI Platform Developer     (Gemini Flash API access)
#   3. Keys tab → Add Key → Create new key → JSON
#   4. Download the JSON file — store it outside the project directory
#
# Security notes:
#   • Never commit the JSON key file to version control
#   • Add *.json to .gitignore (surgical patterns — see .dockerignore)
#   • The .dockerignore file blocks *service-account*.json from Docker images
#   • Rotate keys annually or if compromised
#
# Example:
#   GOOGLE_APPLICATION_CREDENTIALS=/home/yourname/keys/ventlive-sa.json
#   GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json
#
# Leave commented out if using:
#   • gcloud auth application-default login (local development)
#   • Cloud Run attached service account (cloud deployment)
#   • GCE VM default service account (VM deployment)
#
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json


# ══════════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT SETTINGS
# Used by: deploy.sh local target + direct uvicorn invocation
# ══════════════════════════════════════════════════════════════════════════════

# ── Server Port (local) ───────────────────────────────────────────────────────
# Optional. Default: 8000
#
# The port uvicorn binds to when running locally (deploy.sh local).
# Not used for Docker or Cloud Run targets — those use DOCKER_PORT / HOST_PORT.
#
# Change if port 8000 is already in use on your machine:
#   Check: lsof -i :8000
#   Then:  PORT=8001 ./deploy.sh local
#          or set here and run ./deploy.sh local
#
# After changing, update index.html (~line 750):
#   const BACKEND = "http://localhost:YOUR-PORT";
#   Or the ngrok URL if tunneling
PORT=8000


# ══════════════════════════════════════════════════════════════════════════════
# DOCKER SETTINGS
# Used by: deploy.sh docker target
# ══════════════════════════════════════════════════════════════════════════════

# ── Docker Internal Port ──────────────────────────────────────────────────────
# Optional. Default: 8080
#
# The port uvicorn listens on INSIDE the Docker container.
# Must match the EXPOSE directive in Dockerfile and the PORT env var
# that Cloud Run injects (Cloud Run always uses 8080).
#
# Do not change this unless you also update the Dockerfile CMD.
DOCKER_PORT=8080

# ── Docker Host Port ──────────────────────────────────────────────────────────
# Optional. Default: 8080
#
# The port exposed on YOUR MACHINE when running Docker locally.
# This is the left side of the -p flag: -p HOST_PORT:DOCKER_PORT
#
# Change if port 8080 is already in use on your machine:
#   Check:  lsof -i :8080
#   Change: HOST_PORT=9090
#
# After changing, update index.html (~line 750):
#   const BACKEND = "http://localhost:9090";
#
# Common conflicts on port 8080:
#   Jenkins, Jupyter Notebook, other dev servers, GCP Cloud SDK proxy
HOST_PORT=8080

# ── Docker Image Tag ──────────────────────────────────────────────────────────
# Optional. Default: ventlive-ai
#
# The local Docker image name used by deploy.sh docker target.
# For Cloud Run, the image is tagged as gcr.io/GCP_PROJECT/SERVICE_NAME:latest
# regardless of this value.
IMAGE_TAG=ventlive-ai


# ══════════════════════════════════════════════════════════════════════════════
# CLOUD RUN SETTINGS
# Used by: deploy.sh cloudrun target
# ══════════════════════════════════════════════════════════════════════════════

# ── Cloud Run Service Name ────────────────────────────────────────────────────
# Optional. Default: ventlive-ai
#
# The name of the Cloud Run service created or updated on deploy.
# Also used as the Docker image name in Container Registry:
#   gcr.io/GCP_PROJECT/SERVICE_NAME:latest
#
# Rules:
#   • Lowercase letters, numbers, and hyphens only
#   • Must start with a letter
#   • Maximum 49 characters
#
# The service URL will be:
#   https://SERVICE_NAME-xxxx-REGION_CODE.a.run.app
SERVICE_NAME=ventlive-ai


# ══════════════════════════════════════════════════════════════════════════════
# VM DEPLOYMENT SETTINGS
# Used by: deploy.sh vm target
# ══════════════════════════════════════════════════════════════════════════════

# ── VM Instance Name ──────────────────────────────────────────────────────────
# Optional. Default: ventlive-vm
#
# The name of the Google Compute Engine VM instance to deploy to.
# The instance must already exist and be RUNNING before deploying.
#
# Find your instance names:
#   gcloud compute instances list
#   https://console.cloud.google.com/compute/instances
VM_INSTANCE=ventlive-vm

# ── VM Zone ───────────────────────────────────────────────────────────────────
# Optional. Default: us-central1-a
#
# The GCP zone where your VM instance is located.
# Must match the zone shown in GCP Console for your instance.
#
# Common zones:
#   us-central1-a    us-central1-b    us-central1-c
#   us-east1-b       us-east4-a
#   europe-west4-a   asia-southeast1-a
VM_ZONE=us-central1-a

# ── VM SSH User ───────────────────────────────────────────────────────────────
# Optional. Default: current shell user (whoami)
#
# The SSH username for connecting to the VM.
# On GCE this is typically your Google account username
# (the part before the @ in your Google email, with dots replaced by nothing).
#
# Examples:
#   johndoe          (for johndoe@gmail.com)
#   john_doe         (for john.doe@company.com — gcloud may normalize this)
#
# Check your SSH username:
#   gcloud compute ssh YOUR-VM-NAME --zone YOUR-ZONE --dry-run
#   (shows the full SSH command including username)
VM_USER=your-username


# ══════════════════════════════════════════════════════════════════════════════
# QUICK REFERENCE — MINIMUM REQUIRED .env FOR EACH TARGET
# ══════════════════════════════════════════════════════════════════════════════
#
# local (uvicorn):
#   GCP_PROJECT=...
#   GEMINI_API_KEY=...
#
# docker:
#   GCP_PROJECT=...
#   GEMINI_API_KEY=...
#   GOOGLE_APPLICATION_CREDENTIALS=...   (or use gcloud ADC)
#
# cloudrun:
#   GCP_PROJECT=...
#   GEMINI_API_KEY=...
#   GCP_LOCATION=...                     (if not us-central1)
#   SERVICE_NAME=...                     (if not ventlive-ai)
#
# vm:
#   GCP_PROJECT=...
#   GEMINI_API_KEY=...
#   VM_INSTANCE=...
#   VM_ZONE=...
#   VM_USER=...
#
# ══════════════════════════════════════════════════════════════════════════════
